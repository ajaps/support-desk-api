DATABASE_URL=postgres://user:password@localhost:5432/support_desk_development
FRONTEND_URL=http://localhost:5173
REDIS_URL=redis://localhost:6379/0

# Required in production — generate with: rails secret
JWT_SECRET=

APP_HOST=localhost:3000
APP_PROTOCOL=https

# Set to "true" to run SolidQueue inside Puma (Docker sets this automatically)
SOLID_QUEUE_IN_PUMA=true

# Optional in development — get a free key at https://resend.com
RESEND_API_KEY=